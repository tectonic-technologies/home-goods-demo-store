{%- comment -%}
  MARLOW · Social proof + FOMO block (PDP Kit, Module 14 + Reviews)
  Data-driven only: reads real (synthetic-but-consistent) metafields. No fabricated scarcity.
  Namespaces (see pipeline/data/schema.md): reviews.rating, reviews.count,
  merch.units_sold_30d, inv.tier, inv.on_hand. Renders nothing if metafields are absent.
{%- endcomment -%}

{%- assign s = block.settings -%}
{%- assign rating = product.metafields.reviews.rating.value -%}
{%- assign review_count = product.metafields.reviews.count.value -%}
{%- assign sold30 = product.metafields.merch.units_sold_30d.value -%}
{%- assign inv_tier = product.metafields.inv.tier.value -%}
{%- assign on_hand = product.metafields.inv.on_hand.value -%}

<div class="marlow-social-proof" {{ block.shopify_attributes }}>
  {%- if s.show_rating and rating != blank -%}
    <div class="marlow-sp__rating" aria-label="Rated {{ rating }} out of 5">
      <span class="marlow-sp__stars" style="--rating: {{ rating }};" aria-hidden="true">★★★★★</span>
      <span class="marlow-sp__rating-num">{{ rating }}</span>
      {%- if review_count != blank -%}
        <span class="marlow-sp__count">({{ review_count }})</span>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if s.show_velocity and sold30 != blank and sold30 >= s.velocity_threshold -%}
    <p class="marlow-sp__line marlow-sp__velocity">{{ sold30 }} sold in the last 30 days</p>
  {%- endif -%}

  {%- if s.show_stock and inv_tier != blank -%}
    {%- if inv_tier == 'critical' -%}
      <p class="marlow-sp__line marlow-sp__stock is-critical">Low stock{% if on_hand != blank %}, only {{ on_hand }} left{% endif %}</p>
    {%- elsif inv_tier == 'low' -%}
      <p class="marlow-sp__line marlow-sp__stock is-low">Selling quickly{% if on_hand != blank %}, {{ on_hand }} left{% endif %}</p>
    {%- endif -%}
  {%- endif -%}
</div>

{% stylesheet %}
  .marlow-social-proof { display: flex; flex-direction: column; gap: var(--margin-2xs, 6px); margin-block: var(--margin-xs, 10px); }
  .marlow-sp__rating { display: flex; align-items: center; gap: 6px; font-size: 0.9rem; }
  .marlow-sp__stars { position: relative; display: inline-block; letter-spacing: 1px; color: color-mix(in srgb, currentColor 22%, transparent); }
  .marlow-sp__stars::before { content: "★★★★★"; position: absolute; inset-block: 0; inset-inline-start: 0; overflow: hidden; white-space: nowrap; width: calc(var(--rating, 0) / 5 * 100%); color: currentColor; }
  .marlow-sp__rating-num { font-weight: 600; }
  .marlow-sp__count { opacity: 0.6; }
  .marlow-sp__line { margin: 0; font-size: 0.85rem; opacity: 0.85; }
  .marlow-sp__stock.is-critical { color: #9a3b2f; opacity: 1; }
  .marlow-sp__stock.is-low { opacity: 0.9; }
{% endstylesheet %}

{% schema %}
{
  "name": "MARLOW · Social proof",
  "tag": null,
  "settings": [
    { "type": "paragraph", "content": "Data-driven rating, sales velocity, and low-stock signals. Reads product metafields loaded by the MARLOW data pipeline." },
    { "type": "checkbox", "id": "show_rating", "label": "Show star rating", "default": true },
    { "type": "checkbox", "id": "show_velocity", "label": "Show units sold (30 days)", "default": true },
    { "type": "range", "id": "velocity_threshold", "label": "Hide velocity below", "min": 0, "max": 200, "step": 5, "default": 10 },
    { "type": "checkbox", "id": "show_stock", "label": "Show low-stock signal", "default": true }
  ],
  "presets": [
    { "name": "MARLOW · Social proof" }
  ]
}
{% endschema %}
